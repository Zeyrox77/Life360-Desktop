# Copy this file to ".env" and adjust if needed. All values are optional and
# have sensible defaults - you do NOT put your Life360 account credentials here.
# You log in with your email and password directly in the web interface.

# Host and port the local server binds to.
LIFE360_HOST=127.0.0.1
LIFE360_PORT=8360

# Base URL of the Life360 REST API (rarely needs changing).
# LIFE360_API_BASE_URL=https://api.life360.com/v3

# Browser fingerprint curl_cffi impersonates to get past Cloudflare.
# Safari/iOS profiles work best with Life360. Try "safari17_0" or "chrome"
# only if the default stops working.
# LIFE360_IMPERSONATE=safari_ios

# Upstream request timeout in seconds.
# LIFE360_REQUEST_TIMEOUT=20
